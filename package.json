{
  "name": "pos-desktop",
  "version": "1.0.0",
  "description": "Aplikasi POS Desktop offline-first",
  "homepage": "https://pos.desktop",
  "author": {
    "name": "BPH Migas",
    "email": "feri@bphmigas.com"
  },
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev --watch",
    "build": "electron-vite build",
    "obfuscate": "node scripts/obfuscate.mjs",
    "start": "electron-vite build && electron-builder",
    "dist": "electron-vite build && node scripts/obfuscate.mjs && electron-builder"
  },
  "keywords": [],
  "license": "ISC",
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@tailwindcss/vite": "^4.2.4",
    "@vitejs/plugin-vue": "^6.0.6",
    "daisyui": "^5.5.19",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "javascript-obfuscator": "^5.4.2",
    "tailwindcss": "^4.2.4"
  },
  "dependencies": {
    "axios": "^1.15.2",
    "better-sqlite3": "^12.9.0",
    "bonjour-service": "^1.3.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "vue": "^3.5.33",
    "vue-router": "^5.0.6"
  },
  "build": {
    "appId": "com.pos.desktop",
    "productName": "POS Desktop",
    "directories": {
      "output": "dist"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    }
  }
}
